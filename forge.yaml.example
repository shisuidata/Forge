# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  Forge 统一配置文件                                                       ║
# ║  修改后无需重启，下次启动自动生效。                                         ║
# ║  环境变量（.env）优先级高于此文件，可用于覆盖敏感信息。                        ║
# ╚══════════════════════════════════════════════════════════════════════════╝

# ── 飞书机器人 ────────────────────────────────────────────────────────────────
feishu:
  app_id:             ""           # 飞书开放平台 App ID，格式 cli_xxxxxxxx
  app_secret:         ""           # 飞书 App Secret
  verification_token: ""           # 事件订阅验证 Token（HTTP 模式用，长连接可留空）
  encrypt_key:        ""           # 消息加密密钥（不加密留空）

# ── LLM 模型 ─────────────────────────────────────────────────────────────────
llm:
  provider:  "anthropic"           # anthropic | openai（openai 兼容所有接口）
  api_key:   ""                    # API Key（建议放 .env，不要提交到 git）
  model:     "claude-sonnet-4-6"  # 模型 ID
  base_url:  ""                    # 仅 openai 模式需要，如 https://api.deepseek.com/v1

# ── Embedding 模型（RAG 召回用）────────────────────────────────────────────────
embedding:
  api_key:   ""                    # 留空则复用 llm.api_key
  base_url:  "https://api.minimaxi.com/v1"
  model:     "embo-01"
  top_k:     5                     # 每次查询最多召回几张表

# ── 数据库连接 ────────────────────────────────────────────────────────────────
database:
  url: ""
  # 测试数据集示例：
  #   sqlite:///./tests/datasets/small/database.db     ← 4 张表小库
  #   sqlite:///./tests/datasets/large/database.db     ← 200 张表电商数仓
  # 生产示例：
  #   postgresql://user:pass@localhost:5432/mydb

# ── Registry 文件路径 ─────────────────────────────────────────────────────────
# 三套测试数据集可选，取消注释切换：
registry:
  # ── small（4 张表）──
  # schema_path:          "tests/datasets/small/schema.registry.json"
  # metrics_path:         "tests/datasets/small/metrics.registry.yaml"

  # ── large（200 张表电商数仓，默认）──
  schema_path:          "tests/datasets/large/schema.registry.json"
  metrics_path:         "tests/datasets/large/metrics.registry.yaml"
  disambiguations_path: "tests/datasets/large/disambiguations.registry.yaml"
  conventions_path:     "tests/datasets/large/field_conventions.registry.yaml"

  # ── spider（Spider2-Lite，学术 benchmark）──
  # schema_path:          "tests/datasets/spider/schema.registry.json"

# ── Staging 目录（用户交互确认暂存区）─────────────────────────────────────────
staging:
  dir: ".forge/staging"   # 存放待入库的用户确认歧义消除记录

# ── Web 服务器（Admin UI）─────────────────────────────────────────────────────
server:
  host: "0.0.0.0"
  port: 8000
