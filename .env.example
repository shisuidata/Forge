# ╔══════════════════════════════════════════════════════════════════════╗
# ║  Forge 环境变量配置                                                   ║
# ║  复制为 .env 后填入实际值。环境变量优先级高于 forge.yaml。               ║
# ╚══════════════════════════════════════════════════════════════════════╝

# ── LLM（必填）────────────────────────────────────────────────────────
LLM_PROVIDER=anthropic
LLM_API_KEY=
LLM_MODEL=claude-sonnet-4-6

# OpenAI 兼容模型示例（DeepSeek / MiniMax / 本地模型等）：
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-xxx
# LLM_MODEL=deepseek-chat
# LLM_BASE_URL=https://api.deepseek.com/v1

# ── Embedding（必填，用于 Schema RAG 召回）─────────────────────────────
# 推荐：硅基流动 bge-m3（免费，中文语义优）
EMBED_API_KEY=
EMBED_BASE_URL=https://api.siliconflow.cn/v1
EMBED_MODEL=BAAI/bge-m3

# ── 数据库（demo-setup.sh 会自动填入 Demo SQLite）─────────────────────
DATABASE_URL=

# ── 飞书 Bot（可选，不用飞书可留空）───────────────────────────────────
FEISHU_APP_ID=
FEISHU_APP_SECRET=
