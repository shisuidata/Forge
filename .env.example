# Feishu App credentials (from open.feishu.cn)
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FEISHU_VERIFICATION_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FEISHU_ENCRYPT_KEY=

# LLM — Anthropic (default)
LLM_PROVIDER=anthropic
LLM_API_KEY=sk-ant-xxxxxxxx
LLM_MODEL=claude-sonnet-4-6

# LLM — OpenAI-compatible alternative
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-xxxxxxxx
# LLM_MODEL=gpt-4o
# LLM_BASE_URL=https://api.openai.com/v1

# Database (for forge sync + query execution)
DATABASE_URL=postgresql://user:pass@localhost:5432/mydb

# Demo SQLite database (quick local test, no server needed)
# DATABASE_URL=sqlite:////Volumes/WorkSpace/90_Dev/Forge/demo/forge_demo.db

# Registry path (default: schema.registry.json in project root)
REGISTRY_PATH=schema.registry.json
