{
  "tables": {
    "users": {
      "description": "用户主表：注册用户信息，含城市、VIP 等级、注册时间",
      "columns": {
        "id": {},
        "name": {
          "enum": [
            "冯俊", "刘强", "吴浩", "周婷", "孙磊",
            "张伟", "李娜", "王芳", "秦悦", "蒋欣",
            "许晨", "赵雪", "郑丽", "陈明", "韩冰"
          ]
        },
        "city": {
          "enum": ["上海", "北京", "广州", "成都", "杭州", "武汉", "深圳", "西安"]
        },
        "created_at": {},
        "is_vip": {
          "enum": [0, 1]
        }
      }
    },
    "orders": {
      "description": "订单主表：记录用户下单行为，含订单状态、总金额、下单时间",
      "columns": {
        "id": {},
        "user_id": {
          "nullable": true
        },
        "status": {
          "enum": ["completed", "pending", "cancelled"]
        },
        "total_amount": {},
        "created_at": {}
      }
    },
    "order_items": {
      "description": "订单明细表：每笔订单包含的商品行，含数量和单价",
      "columns": {
        "id": {},
        "order_id": {},
        "product_id": {},
        "quantity": {
          "enum": [1, 2, 3, 4]
        },
        "unit_price": {}
      }
    },
    "products": {
      "description": "商品主表：商品名称、品类分类、成本价",
      "columns": {
        "id": {},
        "name": {
          "enum": [
            "AirPods Pro", "MacBook Air", "iPhone 15",
            "优衣库 T恤", "宜家书架", "戴森吸尘器",
            "无印良品外套", "有机坚果礼盒", "李宁运动鞋", "茅台飞天"
          ]
        },
        "category": {
          "enum": ["家居", "服装", "电子产品", "食品"]
        },
        "cost_price": {}
      }
    }
  }
}
